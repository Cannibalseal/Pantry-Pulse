# Database configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pantry_pulse
DB_USER=your_username
DB_PASSWORD=your_password

# App config
SECRET_KEY=your-secret-key
DEBUG=True

# Scraping & scheduling
SCRAPE_INTERVAL_MINUTES=1440
SELENIUM_HEADLESS=True
# Optional: override products to scrape (pipe-separated)
# SCRAPE_PRODUCTS=Mlieko 2.5% 1l|Vajcia 10ks L|Chlieb 500g|Maslo 250g

# Flask run settings (optional)
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

